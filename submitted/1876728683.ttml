<tt xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><iTunesMetadata><songwriters><songwriter>n-buna</songwriter></songwriters></iTunesMetadata><amll:meta key="musicName" value="ヒッチコック (Re-Recording)"/><amll:meta key="musicName" value="Hitchcock (Re-Recording)"/><amll:meta key="musicName" value="ヒッチコック (Hitchcock) (Re-Recording)"/><amll:meta key="musicName" value="ヒッチコック - Re-Recording"/><amll:meta key="artists" value="ヨルシカ"/><amll:meta key="artists" value="Yorushika"/><amll:meta key="album" value="二人称"/><amll:meta key="album" value="second person"/><amll:meta key="ncmMusicId" value="3355479296"/><amll:meta key="appleMusicId" value="1876728683"/><amll:meta key="isrc" value="JPPO02600141"/><amll:meta key="ttmlAuthorGithubLogin" value="WTP016-CN"/><amll:meta key="qqMusicId" value="002doXqM27Cny1"/><amll:meta key="spotifyId" value="1kaGaPZjsbA0y3CFjqroAc"/><amll:meta key="ttmlAuthorGithub" value="66893541"/></metadata></head><body dur="03:26.998"><div begin="00:00.687" end="03:26.998"><p begin="00:00.687" end="00:05.444" ttm:agent="v1" itunes:key="L1"><span begin="00:00.687" end="00:00.811">「</span><span begin="00:00.811" end="00:01.135">雨</span><span begin="00:01.135" end="00:01.315">の</span><span begin="00:01.315" end="00:01.621">匂</span><span begin="00:01.621" end="00:01.866">い</span><span begin="00:01.866" end="00:02.050">に</span><span begin="00:02.050" end="00:02.371">懐</span><span begin="00:02.371" end="00:02.544">か</span><span begin="00:02.544" end="00:02.727">し</span><span begin="00:02.727" end="00:02.928">く</span><span begin="00:02.928" end="00:03.106">な</span><span begin="00:03.106" end="00:03.259">る</span><span begin="00:03.259" end="00:03.424">の</span><span begin="00:03.424" end="00:03.613">は</span><span begin="00:03.613" end="00:03.978">何</span><span begin="00:03.978" end="00:04.152">で</span><span begin="00:04.152" end="00:04.335">な</span><span begin="00:04.335" end="00:04.518">ん</span><span begin="00:04.518" end="00:04.706">で</span><span begin="00:04.706" end="00:04.809">し</span><span begin="00:04.809" end="00:04.912">ょ</span><span begin="00:04.913" end="00:04.982">う</span><span begin="00:04.982" end="00:06.357">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">“为什么雨的气息 总会让人心生怀念呢</span></p><p begin="00:06.357" end="00:11.208" ttm:agent="v1" itunes:key="L2"><span begin="00:06.357" end="00:06.693">夏</span><span begin="00:06.693" end="00:06.861">が</span><span begin="00:06.861" end="00:07.189">近</span><span begin="00:07.189" end="00:07.437">づ</span><span begin="00:07.437" end="00:07.441">く</span><span begin="00:07.441" end="00:07.616">と</span><span begin="00:07.616" end="00:07.937">胸</span><span begin="00:07.937" end="00:08.121">が</span><span begin="00:08.121" end="00:08.504">騒</span><span begin="00:08.504" end="00:08.760">め</span><span begin="00:08.760" end="00:08.936">く</span><span begin="00:08.936" end="00:09.105">の</span><span begin="00:09.105" end="00:09.265">は</span><span begin="00:09.265" end="00:09.593">何</span><span begin="00:09.593" end="00:09.785">で</span><span begin="00:09.785" end="00:09.980">な</span><span begin="00:09.980" end="00:10.175">ん</span><span begin="00:10.176" end="00:10.345">で</span><span begin="00:10.345" end="00:10.448">し</span><span begin="00:10.449" end="00:10.552">ょ</span><span begin="00:10.552" end="00:10.655">う</span><span begin="00:10.656" end="00:11.619">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">为什么一到了夏天 心中就总感觉静不下来呢</span></p><p begin="00:11.619" end="00:16.851" ttm:agent="v1" itunes:key="L3"><span begin="00:11.619" end="00:12.019">人</span><span begin="00:12.019" end="00:12.236">に</span><span begin="00:12.236" end="00:12.667">笑</span><span begin="00:12.667" end="00:12.859">わ</span><span begin="00:12.859" end="00:13.092">れ</span><span begin="00:13.092" end="00:13.291">た</span><span begin="00:13.291" end="00:13.492">ら</span><span begin="00:13.492" end="00:14.035">涙</span><span begin="00:14.035" end="00:14.227">が</span><span begin="00:14.227" end="00:14.411">出</span><span begin="00:14.411" end="00:14.596">る</span><span begin="00:14.596" end="00:14.771">の</span><span begin="00:14.771" end="00:14.947">は</span><span begin="00:14.947" end="00:15.243">何</span><span begin="00:15.243" end="00:15.443">で</span><span begin="00:15.443" end="00:15.623">な</span><span begin="00:15.623" end="00:15.803">ん</span><span begin="00:15.803" end="00:15.987">で</span><span begin="00:15.987" end="00:16.093">し</span><span begin="00:16.094" end="00:16.200">ょ</span><span begin="00:16.200" end="00:16.306">う</span><span begin="00:16.307" end="00:17.597">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">为什么一被人嘲笑 就总是会掉眼泪呢</span></p><p begin="00:17.597" end="00:22.443" ttm:agent="v1" itunes:key="L4"><span begin="00:17.597" end="00:17.757">そ</span><span begin="00:17.757" end="00:17.965">れ</span><span begin="00:17.965" end="00:18.173">で</span><span begin="00:18.173" end="00:18.413">も</span><span begin="00:18.413" end="00:18.630">い</span><span begin="00:18.630" end="00:18.829">つ</span><span begin="00:18.829" end="00:19.013">か</span><span begin="00:19.013" end="00:19.389">報</span><span begin="00:19.389" end="00:19.573">わ</span><span begin="00:19.573" end="00:19.765">れ</span><span begin="00:19.765" end="00:19.804">る</span><span begin="00:19.804" end="00:19.980">か</span><span begin="00:19.980" end="00:20.172">ら</span><span begin="00:20.172" end="00:20.308">と</span><span begin="00:20.308" end="00:20.701">思</span><span begin="00:20.701" end="00:20.948">え</span><span begin="00:20.948" end="00:21.140">ば</span><span begin="00:21.140" end="00:21.254">い</span><span begin="00:21.255" end="00:21.369">い</span><span begin="00:21.369" end="00:21.483">ん</span><span begin="00:21.644" end="00:21.748">し</span><span begin="00:21.748" end="00:21.852">ょ</span><span begin="00:21.852" end="00:21.956">う</span><span begin="00:21.956" end="00:22.627">か。」</span><span ttm:role="x-translation" xml:lang="zh-CN">就算这样 我只要相信这一切都会有所回报就够了吗”</span></p><p begin="00:22.867" end="00:28.363" ttm:agent="v1" itunes:key="L5"><span begin="00:22.867" end="00:23.043">さ</span><span begin="00:23.043" end="00:23.219">よ</span><span begin="00:23.219" end="00:23.395">な</span><span begin="00:23.395" end="00:23.551">ら</span><span begin="00:23.551" end="00:23.707">っ</span><span begin="00:23.707" end="00:23.915">て</span><span begin="00:23.915" end="00:24.467">言</span><span begin="00:24.467" end="00:24.699">葉</span><span begin="00:24.699" end="00:25.411">で</span><span begin="00:25.698" end="00:25.822">こ</span><span begin="00:25.823" end="00:25.947">ん</span><span begin="00:25.947" end="00:26.155">な</span><span begin="00:26.155" end="00:26.507">に</span><span begin="00:26.507" end="00:27.035">胸</span><span begin="00:27.035" end="00:27.227">を</span><span begin="00:27.227" end="00:27.411">裂</span><span begin="00:27.411" end="00:27.611">い</span><span begin="00:27.611" end="00:28.363">て</span><span ttm:role="x-translation" xml:lang="zh-CN">那句道别 原来如此撕心裂肺</span></p><p begin="00:28.531" end="00:36.484" ttm:agent="v1" itunes:key="L6"><span begin="00:28.531" end="00:28.843">今</span><span begin="00:28.843" end="00:29.026">も</span><span begin="00:29.026" end="00:29.190">た</span><span begin="00:29.190" end="00:29.354">っ</span><span begin="00:29.355" end="00:29.555">た</span><span begin="00:29.555" end="00:29.915">数</span><span begin="00:29.915" end="00:30.235">瞬</span><span begin="00:30.235" end="00:30.893">の</span><span begin="00:30.893" end="00:31.268">夕</span><span begin="00:31.268" end="00:31.461">焼</span><span begin="00:31.461" end="00:31.685">け</span><span begin="00:31.685" end="00:33.285">に</span><span begin="00:34.565" end="00:34.892">足</span><span begin="00:34.892" end="00:35.052">が</span><span begin="00:35.052" end="00:35.212">止</span><span begin="00:35.212" end="00:35.352">ま</span><span begin="00:35.353" end="00:35.493">っ</span><span begin="00:35.493" end="00:35.685">て</span><span begin="00:35.685" end="00:35.877">い</span><span begin="00:35.878" end="00:36.484">た</span><span ttm:role="x-translation" xml:lang="zh-CN">时至今日 我依然会为了那转瞬即逝的夕阳 驻足不前</span></p><p begin="00:36.701" end="00:39.325" ttm:agent="v1" itunes:key="L7"><span begin="00:36.701" end="00:36.852">「</span><span begin="00:36.852" end="00:37.092">先</span><span begin="00:37.092" end="00:37.405">生、</span><span begin="00:37.405" end="00:37.725">人</span><span begin="00:37.725" end="00:38.084">生</span><span begin="00:38.084" end="00:38.452">相</span><span begin="00:38.452" end="00:38.836">談</span><span begin="00:38.836" end="00:39.141">で</span><span begin="00:39.141" end="00:39.580">す。</span><span ttm:role="x-translation" xml:lang="zh-CN">“老师、关于人生 我有不明白的地方</span></p><p begin="00:39.580" end="00:42.076" ttm:agent="v1" itunes:key="L8"><span begin="00:39.580" end="00:39.748">こ</span><span begin="00:39.748" end="00:39.917">の</span><span begin="00:39.917" end="00:40.276">先</span><span begin="00:40.276" end="00:40.428">ど</span><span begin="00:40.429" end="00:40.581">う</span><span begin="00:40.581" end="00:40.837">な</span><span begin="00:40.837" end="00:41.012">ら</span><span begin="00:41.012" end="00:41.349">楽</span><span begin="00:41.349" end="00:41.525">で</span><span begin="00:41.525" end="00:41.716">す</span><span begin="00:41.716" end="00:42.324">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">今后该怎么样 才能活的轻松呢</span></p><p begin="00:42.324" end="00:46.788" ttm:agent="v1" itunes:key="L9"><span begin="00:42.324" end="00:42.508">そ</span><span begin="00:42.509" end="00:42.693">ん</span><span begin="00:42.693" end="00:42.884">な</span><span begin="00:42.884" end="00:43.085">の</span><span begin="00:43.085" end="00:43.460">誰</span><span begin="00:43.460" end="00:43.644">も</span><span begin="00:43.644" end="00:43.844">わ</span><span begin="00:43.844" end="00:44.029">か</span><span begin="00:44.029" end="00:44.213">り</span><span begin="00:44.213" end="00:44.397">は</span><span begin="00:44.397" end="00:44.588">し</span><span begin="00:44.588" end="00:44.772">な</span><span begin="00:44.772" end="00:44.972">い</span><span begin="00:44.972" end="00:45.112">よ</span><span begin="00:45.112" end="00:45.288">な</span><span begin="00:45.288" end="00:45.464">ん</span><span begin="00:45.464" end="00:45.671">て</span><span begin="00:45.671" end="00:45.863">言</span><span begin="00:45.863" end="00:46.040">わ</span><span begin="00:46.040" end="00:46.215">れ</span><span begin="00:46.215" end="00:46.519">ま</span><span begin="00:46.519" end="00:46.680">す</span><span begin="00:46.680" end="00:47.011">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">你会告诉我 这种问题 没有人知道答案吗</span></p><p begin="00:47.011" end="00:50.522" ttm:agent="v1" itunes:key="L10"><span begin="00:47.011" end="00:47.211">ほ</span><span begin="00:47.211" end="00:47.940">ら、</span><span begin="00:47.940" end="00:48.299">苦</span><span begin="00:48.299" end="00:48.481">し</span><span begin="00:48.481" end="00:48.705">さ</span><span begin="00:48.705" end="00:48.873">な</span><span begin="00:48.873" end="00:49.041">ん</span><span begin="00:49.041" end="00:49.233">て</span><span begin="00:49.233" end="00:49.425">欲</span><span begin="00:49.425" end="00:49.593">し</span><span begin="00:49.593" end="00:49.761">い</span><span begin="00:49.761" end="00:49.954">わ</span><span begin="00:49.954" end="00:50.137">け</span><span begin="00:50.137" end="00:50.473">な</span><span begin="00:50.473" end="00:50.793">い。</span><span ttm:role="x-translation" xml:lang="zh-CN">你瞧、我也不是想让自己难受</span></p><p begin="00:50.793" end="00:53.508" ttm:agent="v1" itunes:key="L11"><span begin="00:50.793" end="00:51.194">何</span><span begin="00:51.194" end="00:51.393">も</span><span begin="00:51.393" end="00:51.593">し</span><span begin="00:51.593" end="00:51.794">な</span><span begin="00:51.794" end="00:51.977">い</span><span begin="00:51.977" end="00:52.185">で</span><span begin="00:52.185" end="00:52.361">生</span><span begin="00:52.361" end="00:52.545">き</span><span begin="00:52.545" end="00:52.804">て</span><span begin="00:52.804" end="00:53.003">い</span><span begin="00:53.003" end="00:53.283">た</span><span begin="00:53.283" end="00:53.558">い。</span><span ttm:role="x-translation" xml:lang="zh-CN">我只是想浑浑噩噩无所作为地活下去</span></p><p begin="00:53.508" end="00:57.219" ttm:agent="v1" itunes:key="L12"><span begin="00:53.508" end="00:53.924">青</span><span begin="00:53.924" end="00:54.316">空</span><span begin="00:54.316" end="00:54.477">だ</span><span begin="00:54.477" end="00:54.700">け</span><span begin="00:54.700" end="00:54.908">が</span><span begin="00:54.908" end="00:55.101">見</span><span begin="00:55.101" end="00:55.292">た</span><span begin="00:55.292" end="00:55.508">い</span><span begin="00:55.508" end="00:55.741">の</span><span begin="00:55.741" end="00:55.836">は</span><span begin="00:55.836" end="00:56.172">我</span><span begin="00:56.172" end="00:56.549">儘</span><span begin="00:56.549" end="00:56.796">で</span><span begin="00:56.796" end="00:56.940">す</span><span begin="00:56.940" end="00:57.364">か。」</span><span ttm:role="x-translation" xml:lang="zh-CN">只想看着蓝天 难道也算是一种任性吗”</span></p><p begin="01:11.075" end="01:16.064" ttm:agent="v1" itunes:key="L13"><span begin="01:11.075" end="01:11.323">「</span><span begin="01:11.323" end="01:11.700">胸</span><span begin="01:11.700" end="01:11.883">が</span><span begin="01:11.883" end="01:12.164">痛</span><span begin="01:12.165" end="01:12.399">ん</span><span begin="01:12.399" end="01:12.559">で</span><span begin="01:12.559" end="01:12.783">も</span><span begin="01:12.783" end="01:13.127">嘘</span><span begin="01:13.127" end="01:13.295">が</span><span begin="01:13.295" end="01:13.487">つ</span><span begin="01:13.487" end="01:13.743">け</span><span begin="01:13.743" end="01:13.904">る</span><span begin="01:13.904" end="01:14.049">の</span><span begin="01:14.049" end="01:14.223">は</span><span begin="01:14.223" end="01:14.527">何</span><span begin="01:14.527" end="01:14.735">で</span><span begin="01:14.735" end="01:14.919">な</span><span begin="01:14.919" end="01:15.103">ん</span><span begin="01:15.103" end="01:15.279">で</span><span begin="01:15.279" end="01:15.391">し</span><span begin="01:15.391" end="01:15.503">ょ</span><span begin="01:15.503" end="01:15.615">う</span><span begin="01:15.615" end="01:16.823">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">“为什么心里都这么痛了 还是能照常撒下谎言呢</span></p><p begin="01:16.823" end="01:21.617" ttm:agent="v1" itunes:key="L14"><span begin="01:16.823" end="01:17.141">悪</span><span begin="01:17.141" end="01:17.318">い</span><span begin="01:17.318" end="01:17.666">人</span><span begin="01:17.666" end="01:17.838">ば</span><span begin="01:17.838" end="01:18.020">か</span><span begin="01:18.020" end="01:18.228">り</span><span begin="01:18.228" end="01:18.401">が</span><span begin="01:18.401" end="01:18.726">得</span><span begin="01:18.726" end="01:18.911">を</span><span begin="01:18.911" end="01:19.097">し</span><span begin="01:19.097" end="01:19.309">て</span><span begin="01:19.309" end="01:19.480">る</span><span begin="01:19.480" end="01:19.645">の</span><span begin="01:19.645" end="01:19.832">は</span><span begin="01:19.832" end="01:20.158">何</span><span begin="01:20.158" end="01:20.380">で</span><span begin="01:20.380" end="01:20.545">な</span><span begin="01:20.545" end="01:20.710">ん</span><span begin="01:20.710" end="01:20.891">で</span><span begin="01:20.891" end="01:21.002">し</span><span begin="01:21.003" end="01:21.114">ょ</span><span begin="01:21.114" end="01:21.244">う</span><span begin="01:21.245" end="01:22.425">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">为什么坏人们 反而总能得到好处呢</span></p><p begin="01:22.425" end="01:27.555" ttm:agent="v1" itunes:key="L15"><span begin="01:22.425" end="01:22.953">幸</span><span begin="01:22.953" end="01:23.129">せ</span><span begin="01:23.129" end="01:23.313">の</span><span begin="01:23.313" end="01:23.513">文</span><span begin="01:23.513" end="01:23.697">字</span><span begin="01:23.697" end="01:23.989">が</span><span begin="01:23.989" end="01:24.406">￥</span><span begin="01:24.406" end="01:24.618">を</span><span begin="01:24.618" end="01:25.018">含</span><span begin="01:25.018" end="01:25.203">む</span><span begin="01:25.203" end="01:25.378">の</span><span begin="01:25.378" end="01:25.579">は</span><span begin="01:25.579" end="01:25.818">何</span><span begin="01:25.818" end="01:26.010">で</span><span begin="01:26.010" end="01:26.194">な</span><span begin="01:26.194" end="01:26.378">ん</span><span begin="01:26.378" end="01:26.538">で</span><span begin="01:26.538" end="01:26.647">し</span><span begin="01:26.647" end="01:26.756">ょ</span><span begin="01:26.757" end="01:26.866">う</span><span begin="01:26.866" end="01:28.069">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">为什么幸福的幸字中间 居然藏着￥这一符号呢</span></p><p begin="01:28.069" end="01:33.028" ttm:agent="v1" itunes:key="L16"><span begin="01:28.069" end="01:28.509">一</span><span begin="01:28.509" end="01:28.701">つ</span><span begin="01:28.701" end="01:29.007">線</span><span begin="01:29.008" end="01:29.168">を</span><span begin="01:29.168" end="01:29.352">抜</span><span begin="01:29.352" end="01:29.529">け</span><span begin="01:29.529" end="01:29.712">ば</span><span begin="01:29.712" end="01:30.064">辛</span><span begin="01:30.064" end="01:30.225">さ</span><span begin="01:30.225" end="01:30.409">に</span><span begin="01:30.409" end="01:30.553">な</span><span begin="01:30.553" end="01:30.728">る</span><span begin="01:30.728" end="01:30.889">の</span><span begin="01:30.889" end="01:31.108">は</span><span begin="01:31.108" end="01:31.292">わ</span><span begin="01:31.292" end="01:31.483">ざ</span><span begin="01:31.483" end="01:31.683">と</span><span begin="01:31.683" end="01:31.859">な</span><span begin="01:31.859" end="01:32.035">ん</span><span begin="01:32.035" end="01:32.211">で</span><span begin="01:32.211" end="01:32.317">し</span><span begin="01:32.318" end="01:32.424">ょ</span><span begin="01:32.424" end="01:32.530">う</span><span begin="01:32.531" end="01:33.187">か。」</span><span ttm:role="x-translation" xml:lang="zh-CN">而这幸字去掉一横 就会变成辛苦的辛字 难道是故意的吗”</span></p><p begin="01:33.370" end="01:38.754" ttm:agent="v1" itunes:key="L17"><span begin="01:33.370" end="01:33.762">青</span><span begin="01:33.762" end="01:34.109">春</span><span begin="01:34.109" end="01:34.224">っ</span><span begin="01:34.225" end="01:34.474">て</span><span begin="01:34.474" end="01:34.865">値</span><span begin="01:34.865" end="01:35.305">札</span><span begin="01:35.305" end="01:35.929">が</span><span begin="01:36.225" end="01:36.426">背</span><span begin="01:36.426" end="01:36.802">中</span><span begin="01:36.802" end="01:37.137">に</span><span begin="01:37.137" end="01:37.361">貼</span><span begin="01:37.361" end="01:37.706">ら</span><span begin="01:37.706" end="01:37.881">れ</span><span begin="01:37.881" end="01:38.029">て</span><span begin="01:38.029" end="01:38.177">い</span><span begin="01:38.177" end="01:38.754">て</span><span ttm:role="x-translation" xml:lang="zh-CN">名为青春的标签 贴在了背后</span></p><p begin="01:39.046" end="01:47.128" ttm:agent="v1" itunes:key="L18"><span begin="01:39.046" end="01:39.226">ヒ</span><span begin="01:39.226" end="01:39.406">ッ</span><span begin="01:39.407" end="01:39.598">チ</span><span begin="01:39.598" end="01:39.742">コ</span><span begin="01:39.742" end="01:39.886">ッ</span><span begin="01:39.886" end="01:40.111">ク</span><span begin="01:40.111" end="01:40.447">み</span><span begin="01:40.447" end="01:40.647">た</span><span begin="01:40.647" end="01:40.846">い</span><span begin="01:40.846" end="01:40.951">な</span><span begin="01:40.951" end="01:41.135">サ</span><span begin="01:41.135" end="01:41.359">ス</span><span begin="01:41.359" end="01:41.587">ペ</span><span begin="01:41.587" end="01:41.815">ン</span><span begin="01:41.815" end="01:41.995">ス</span><span begin="01:41.995" end="01:43.707">を</span><span begin="01:45.203" end="01:45.363">ど</span><span begin="01:45.363" end="01:45.538">こ</span><span begin="01:45.538" end="01:45.722">か</span><span begin="01:45.722" end="01:45.898">期</span><span begin="01:45.898" end="01:46.322">待</span><span begin="01:46.322" end="01:46.555">し</span><span begin="01:46.555" end="01:46.626">て</span><span begin="01:46.626" end="01:46.697">い</span><span begin="01:46.698" end="01:47.128">た</span><span ttm:role="x-translation" xml:lang="zh-CN">心底却在期待着 一场希区柯克般的悬疑故事</span></p><p begin="01:47.128" end="01:49.934" ttm:agent="v1" itunes:key="L19"><span begin="01:47.128" end="01:47.359">「</span><span begin="01:47.359" end="01:47.679">先</span><span begin="01:47.679" end="01:48.039">生、</span><span begin="01:48.039" end="01:48.203">ど</span><span begin="01:48.203" end="01:48.367">う</span><span begin="01:48.367" end="01:48.615">で</span><span begin="01:48.615" end="01:48.799">も</span><span begin="01:48.799" end="01:48.908">い</span><span begin="01:48.909" end="01:49.018">い</span><span begin="01:49.018" end="01:49.101">ん</span><span begin="01:49.102" end="01:49.294">で</span><span begin="01:49.294" end="01:49.526">す</span><span begin="01:49.526" end="01:50.166">よ。</span><span ttm:role="x-translation" xml:lang="zh-CN">“老师、已经无所谓了啦</span></p><p begin="01:50.166" end="01:52.702" ttm:agent="v1" itunes:key="L20"><span begin="01:50.166" end="01:50.334">生</span><span begin="01:50.334" end="01:50.518">き</span><span begin="01:50.518" end="01:50.694">て</span><span begin="01:50.694" end="01:50.894">る</span><span begin="01:50.894" end="01:51.078">だ</span><span begin="01:51.078" end="01:51.270">け</span><span begin="01:51.270" end="01:51.454">で</span><span begin="01:51.454" end="01:51.870">痛</span><span begin="01:51.870" end="01:51.970">い</span><span begin="01:51.970" end="01:51.974">ん</span><span begin="01:51.974" end="01:52.118">で</span><span begin="01:52.118" end="01:52.342">す</span><span begin="01:52.342" end="01:52.976">よ。</span><span ttm:role="x-translation" xml:lang="zh-CN">单单是活着 都已经痛彻心扉了</span></p><p begin="01:52.976" end="01:57.536" ttm:agent="v1" itunes:key="L21"><span begin="01:52.976" end="01:53.120">ニ</span><span begin="01:53.120" end="01:53.264">ー</span><span begin="01:53.264" end="01:53.364">チ</span><span begin="01:53.364" end="01:53.464">ェ</span><span begin="01:53.464" end="01:53.688">も</span><span begin="01:53.688" end="01:53.896">フ</span><span begin="01:53.896" end="01:54.088">ロ</span><span begin="01:54.088" end="01:54.272">イ</span><span begin="01:54.272" end="01:54.489">ト</span><span begin="01:54.489" end="01:54.575">も</span><span begin="01:54.575" end="01:54.759">こ</span><span begin="01:54.759" end="01:54.959">の</span><span begin="01:54.959" end="01:55.344">穴</span><span begin="01:55.344" end="01:55.536">の</span><span begin="01:55.536" end="01:55.728">埋</span><span begin="01:55.728" end="01:55.912">め</span><span begin="01:55.912" end="01:56.280">方</span><span begin="01:56.280" end="01:56.464">は</span><span begin="01:56.464" end="01:56.648">書</span><span begin="01:56.648" end="01:56.745">か</span><span begin="01:56.745" end="01:56.897">な</span><span begin="01:56.897" end="01:57.013">い</span><span begin="01:57.014" end="01:57.130">ん</span><span begin="01:57.130" end="01:57.586">だ。</span><span ttm:role="x-translation" xml:lang="zh-CN">尼采和佛洛依德 都没有写 该如何填上这块空洞啊</span></p><p begin="01:57.536" end="02:01.279" ttm:agent="v1" itunes:key="L22"><span begin="01:57.536" end="01:57.777">た</span><span begin="01:57.777" end="01:58.321">だ</span><span begin="01:58.601" end="01:58.985">夏</span><span begin="01:58.985" end="01:59.176">の</span><span begin="01:59.176" end="01:59.584">匂</span><span begin="01:59.584" end="01:59.769">い</span><span begin="01:59.769" end="01:59.960">に</span><span begin="01:59.960" end="02:00.144">目</span><span begin="02:00.144" end="02:00.337">を</span><span begin="02:00.337" end="02:00.616">瞑</span><span begin="02:00.616" end="02:00.699">っ</span><span begin="02:00.699" end="02:01.446">て、</span><span ttm:role="x-translation" xml:lang="zh-CN">我只想闭上眼 闻一闻夏日的气息</span></p><p begin="02:01.446" end="02:03.910" ttm:agent="v1" itunes:key="L23"><span begin="02:01.446" end="02:01.832">雲</span><span begin="02:01.832" end="02:02.017">の</span><span begin="02:02.017" end="02:02.305">高</span><span begin="02:02.305" end="02:02.470">さ</span><span begin="02:02.470" end="02:02.652">を</span><span begin="02:02.652" end="02:03.062">指</span><span begin="02:03.062" end="02:03.230">で</span><span begin="02:03.230" end="02:03.415">描</span><span begin="02:03.415" end="02:03.657">こ</span><span begin="02:03.657" end="02:04.253">う。</span><span ttm:role="x-translation" xml:lang="zh-CN">伸出手指 比划白云究竟有多高</span></p><p begin="02:04.253" end="02:07.844" ttm:agent="v1" itunes:key="L24"><span begin="02:04.253" end="02:04.646">想</span><span begin="02:04.646" end="02:04.870">い</span><span begin="02:04.870" end="02:05.053">出</span><span begin="02:05.053" end="02:05.277">だ</span><span begin="02:05.277" end="02:05.429">け</span><span begin="02:05.429" end="02:05.571">が</span><span begin="02:05.571" end="02:05.763">見</span><span begin="02:05.763" end="02:05.914">た</span><span begin="02:05.914" end="02:06.098">い</span><span begin="02:06.098" end="02:06.290">の</span><span begin="02:06.290" end="02:06.450">は</span><span begin="02:06.450" end="02:06.818">我</span><span begin="02:06.818" end="02:07.163">儘</span><span begin="02:07.163" end="02:07.426">で</span><span begin="02:07.426" end="02:07.587">す</span><span begin="02:07.587" end="02:07.946">か。」</span><span ttm:role="x-translation" xml:lang="zh-CN">只想沉浸在回忆中 难道也算是一种任性吗”</span></p><p begin="02:18.459" end="02:21.874" ttm:agent="v1" itunes:key="L25"><span begin="02:18.459" end="02:18.616">「</span><span begin="02:18.616" end="02:18.801">ド</span><span begin="02:18.801" end="02:18.989">ラ</span><span begin="02:18.989" end="02:19.148">マ</span><span begin="02:19.148" end="02:19.292">チ</span><span begin="02:19.292" end="02:19.442">ッ</span><span begin="02:19.443" end="02:19.685">ク</span><span begin="02:19.685" end="02:20.036">に</span><span begin="02:20.036" end="02:20.380">人</span><span begin="02:20.380" end="02:20.546">が</span><span begin="02:20.546" end="02:20.714">死</span><span begin="02:20.714" end="02:20.835">ぬ</span><span begin="02:20.835" end="02:21.031">ス</span><span begin="02:21.031" end="02:21.241">ト</span><span begin="02:21.241" end="02:21.416">ー</span><span begin="02:21.416" end="02:21.520">リ</span><span begin="02:21.520" end="02:21.551">ー</span><span begin="02:21.551" end="02:21.688">っ</span><span begin="02:21.688" end="02:21.874">て</span><span ttm:role="x-translation" xml:lang="zh-CN">“那些充满了戏剧性 还会死人的故事</span></p><p begin="02:21.874" end="02:23.823" ttm:agent="v1" itunes:key="L26"><span begin="02:21.874" end="02:22.050">売</span><span begin="02:22.050" end="02:22.239">れ</span><span begin="02:22.239" end="02:22.416">る</span><span begin="02:22.416" end="02:22.512">じ</span><span begin="02:22.512" end="02:22.575">ゃ</span><span begin="02:22.575" end="02:22.755">な</span><span begin="02:22.755" end="02:23.033">い</span><span begin="02:23.033" end="02:23.187">で</span><span begin="02:23.187" end="02:23.349">す</span><span begin="02:23.349" end="02:24.273">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">不是都很畅销吗</span></p><p begin="02:24.273" end="02:29.255" ttm:agent="v1" itunes:key="L27"><span begin="02:24.273" end="02:24.618">花</span><span begin="02:24.618" end="02:24.809">の</span><span begin="02:24.809" end="02:25.009">散</span><span begin="02:25.009" end="02:25.193">り</span><span begin="02:25.193" end="02:25.649">際</span><span begin="02:25.649" end="02:25.842">に</span><span begin="02:25.842" end="02:26.017">す</span><span begin="02:26.017" end="02:26.210">ら</span><span begin="02:26.210" end="02:26.393">値</span><span begin="02:26.393" end="02:26.570">が</span><span begin="02:26.570" end="02:26.738">付</span><span begin="02:26.738" end="02:27.073">く</span><span begin="02:27.073" end="02:27.266">の</span><span begin="02:27.266" end="02:27.442">も</span><span begin="02:27.442" end="02:27.849">嫌</span><span begin="02:27.849" end="02:28.050">に</span><span begin="02:28.050" end="02:28.305">な</span><span begin="02:28.305" end="02:28.374">り</span><span begin="02:28.374" end="02:28.558">ま</span><span begin="02:28.558" end="02:28.711">し</span><span begin="02:28.711" end="02:29.967">た。</span><span ttm:role="x-translation" xml:lang="zh-CN">就连鲜花凋零的刹那 都被明码标价 我实在是厌倦了啊</span></p><p begin="02:29.967" end="02:33.374" ttm:agent="v1" itunes:key="L28"><span begin="02:29.967" end="02:30.375">先</span><span begin="02:30.375" end="02:30.702">生</span><span begin="02:30.702" end="02:30.974">の</span><span begin="02:30.974" end="02:31.391">夢</span><span begin="02:31.391" end="02:31.513">は</span><span begin="02:31.513" end="02:31.818">何</span><span begin="02:31.818" end="02:31.974">だ</span><span begin="02:31.974" end="02:32.130">っ</span><span begin="02:32.130" end="02:32.254">た</span><span begin="02:32.254" end="02:32.502">ん</span><span begin="02:32.502" end="02:32.686">で</span><span begin="02:32.686" end="02:32.919">す</span><span begin="02:32.919" end="02:35.397">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">老师 你的梦想又是什么呢</span></p><p begin="02:35.397" end="02:38.851" ttm:agent="v1" itunes:key="L29"><span begin="02:35.397" end="02:35.661">大</span><span begin="02:35.661" end="02:35.925">人</span><span begin="02:35.925" end="02:36.117">に</span><span begin="02:36.117" end="02:36.294">な</span><span begin="02:36.294" end="02:36.462">る</span><span begin="02:36.462" end="02:36.611">と</span><span begin="02:36.611" end="02:36.963">忘</span><span begin="02:36.963" end="02:37.147">れ</span><span begin="02:37.147" end="02:37.230">ち</span><span begin="02:37.230" end="02:37.313">ゃ</span><span begin="02:37.314" end="02:37.507">う</span><span begin="02:37.507" end="02:37.707">も</span><span begin="02:37.707" end="02:37.883">の</span><span begin="02:37.883" end="02:38.047">な</span><span begin="02:38.047" end="02:38.211">ん</span><span begin="02:38.211" end="02:38.507">で</span><span begin="02:38.507" end="02:38.659">す</span><span begin="02:38.659" end="02:39.042">か。」</span><span ttm:role="x-translation" xml:lang="zh-CN">难道是那种长大了之后 就忘掉了的梦想吗”</span></p><p begin="02:40.947" end="02:43.546" ttm:agent="v1" itunes:key="L30"><span begin="02:40.947" end="02:41.155">「</span><span begin="02:41.155" end="02:41.330">先</span><span begin="02:41.330" end="02:41.619">生、</span><span begin="02:41.619" end="02:41.955">人</span><span begin="02:41.955" end="02:42.338">生</span><span begin="02:42.338" end="02:42.691">相</span><span begin="02:42.691" end="02:43.036">談</span><span begin="02:43.036" end="02:43.363">で</span><span begin="02:43.363" end="02:43.763">す。</span><span ttm:role="x-translation" xml:lang="zh-CN">“老师、关于人生 我有不明白的地方</span></p><p begin="02:43.763" end="02:46.323" ttm:agent="v1" itunes:key="L31"><span begin="02:43.763" end="02:43.947">こ</span><span begin="02:43.947" end="02:44.130">の</span><span begin="02:44.130" end="02:44.490">先</span><span begin="02:44.490" end="02:44.638">ど</span><span begin="02:44.638" end="02:44.786">う</span><span begin="02:44.786" end="02:44.987">な</span><span begin="02:44.987" end="02:45.170">ら</span><span begin="02:45.170" end="02:45.539">楽</span><span begin="02:45.539" end="02:45.715">で</span><span begin="02:45.715" end="02:45.914">す</span><span begin="02:45.914" end="02:46.587">か。</span><span ttm:role="x-translation" xml:lang="zh-CN">今后该怎么样 才能活的轻松呢</span></p><p begin="02:46.587" end="02:51.191" ttm:agent="v1" itunes:key="L32"><span begin="02:46.587" end="02:47.130">涙</span><span begin="02:47.130" end="02:47.330">が</span><span begin="02:47.330" end="02:47.730">人</span><span begin="02:47.730" end="02:47.930">を</span><span begin="02:47.930" end="02:48.306">強</span><span begin="02:48.306" end="02:48.391">く</span><span begin="02:48.391" end="02:48.559">す</span><span begin="02:48.559" end="02:48.744">る</span><span begin="02:48.744" end="02:48.927">な</span><span begin="02:48.927" end="02:49.110">ん</span><span begin="02:49