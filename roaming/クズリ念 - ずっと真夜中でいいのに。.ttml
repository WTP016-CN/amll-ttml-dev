<?xml version="1.0" encoding="utf-8"?><tt xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><iTunesMetadata><songwriters><songwriter>ACAね</songwriter></songwriters></iTunesMetadata><amll:meta key="musicName" value="クズリ念"/><amll:meta key="musicName" value="KUZURI"/><amll:meta key="artists" value="ずっと真夜中でいいのに。"/><amll:meta key="artists" value="ZUTOMAYO"/><amll:meta key="album" value="虚仮の一念海馬に託す"/><amll:meta key="isrc" value="JPPO02404478"/><amll:meta key="ncmMusicId" value="2639244959"/><amll:meta key="appleMusicId" value="1770242097"/><amll:meta key="ttmlAuthorGithubLogin" value="WTP016-CN"/><amll:meta key="qqMusicId" value="532063824"/><amll:meta key="qqMusicId" value="0043J7zY3E962M"/><amll:meta key="spotifyId" value="7t79PIxAZwn6RtJzAKoKTI"/></metadata></head><body dur="03:26.054"><div begin="00:08.405" end="03:26.054"><p begin="00:08.405" end="00:14.081" ttm:agent="v1" itunes:key="L1"><span begin="00:08.405" end="00:09.005">心</span><span begin="00:09.005" end="00:09.540">臓</span><span begin="00:09.540" end="00:09.780">こ</span><span begin="00:09.780" end="00:10.045">じ</span><span begin="00:10.045" end="00:10.284">開</span><span begin="00:10.284" end="00:10.548">け</span><span begin="00:10.548" end="00:11.245">て</span><span begin="00:11.245" end="00:11.727">さ</span><span begin="00:11.727" end="00:11.863">ら</span><span begin="00:11.863" end="00:11.999">っ</span><span begin="00:11.999" end="00:12.231">と</span><span begin="00:12.231" end="00:12.345">食</span><span begin="00:12.345" end="00:13.153">べ</span><span begin="00:13.153" end="00:14.081">て</span><span ttm:role="x-translation" xml:lang="zh-CN">撬开心脏，然后快意地吞下</span></p><p begin="00:14.081" end="00:16.276" ttm:agent="v1" itunes:key="L2"><span begin="00:14.081" end="00:14.657">何</span><span begin="00:14.657" end="00:14.978">も</span><span begin="00:14.978" end="00:15.377">感</span><span begin="00:15.377" end="00:15.681">じ</span><span begin="00:15.681" end="00:15.929">な</span><span begin="00:15.929" end="00:16.276">い</span><span ttm:role="x-translation" xml:lang="zh-CN">可什么也没能察觉到</span></p><p begin="00:16.276" end="00:19.855" ttm:agent="v1" itunes:key="L3"><span begin="00:16.276" end="00:17.292">雨</span><span begin="00:17.292" end="00:17.508">の</span><span begin="00:17.508" end="00:17.945">中</span><span begin="00:17.945" end="00:18.085">ず</span><span begin="00:18.085" end="00:18.225">っ</span><span begin="00:18.225" end="00:18.489">と</span><span begin="00:18.489" end="00:18.721">煮</span><span begin="00:18.721" end="00:18.933">込</span><span begin="00:18.933" end="00:18.988">ん</span><span begin="00:18.988" end="00:19.492">で</span><span begin="00:19.492" end="00:19.855">も</span><span ttm:role="x-translation" xml:lang="zh-CN">即使在雨中一直炖煮</span></p><p begin="00:19.855" end="00:23.119" ttm:agent="v1" itunes:key="L4"><span begin="00:19.855" end="00:20.015">ま</span><span begin="00:20.015" end="00:20.183">ず</span><span begin="00:20.183" end="00:20.751">い</span><span begin="00:20.751" end="00:20.959">も</span><span begin="00:20.959" end="00:21.127">の</span><span begin="00:21.127" end="00:21.743">は</span><span begin="00:21.743" end="00:21.939">不</span><span begin="00:21.939" end="00:22.135">味</span><span begin="00:22.135" end="00:23.119">い</span><span ttm:role="x-translation" xml:lang="zh-CN">难过的坏事终究也无法改变</span></p><p begin="00:24.031" end="00:27.611" ttm:agent="v1" itunes:key="L5"><span begin="00:24.031" end="00:24.527">世</span><span begin="00:24.527" end="00:24.983">の</span><span begin="00:24.983" end="00:25.535">中</span><span begin="00:25.535" end="00:25.815">の</span><span begin="00:25.815" end="00:26.079">意</span><span begin="00:26.079" end="00:26.311">図</span><span begin="00:26.311" end="00:26.311">・</span><span begin="00:26.311" end="00:26.583">書</span><span begin="00:26.583" end="00:26.783">が</span><span begin="00:26.783" end="00:27.207">全</span><span begin="00:27.207" end="00:27.611">部</span><span ttm:role="x-translation" xml:lang="zh-CN">人世间所有的思绪和书籍</span></p><p begin="00:27.611" end="00:31.396" ttm:agent="v1" itunes:key="L6"><span begin="00:27.611" end="00:28.155">響</span><span begin="00:28.155" end="00:28.307">く</span><span begin="00:28.307" end="00:28.555">と</span><span begin="00:28.555" end="00:28.723">は</span><span begin="00:28.723" end="00:29.083">限</span><span begin="00:29.083" end="00:29.275">ら</span><span begin="00:29.275" end="00:29.411">な</span><span begin="00:29.411" end="00:29.627">い</span><span begin="00:29.627" end="00:29.867">こ</span><span begin="00:29.867" end="00:29.996">と</span><span begin="00:29.996" end="00:30.237">わ</span><span begin="00:30.237" end="00:30.492">か</span><span begin="00:30.492" end="00:30.788">る</span><span begin="00:30.788" end="00:30.971">よ</span><span begin="00:30.971" end="00:31.183">も</span><span begin="00:31.184" end="00:31.396">う</span><span ttm:role="x-translation" xml:lang="zh-CN">并非都能让人产生共鸣 这我已经了然</span></p><p begin="00:31.396" end="00:35.262" ttm:agent="v1" itunes:key="L7"><span begin="00:31.396" end="00:31.587">で</span><span begin="00:31.587" end="00:31.747">も</span><span begin="00:31.747" end="00:32.227">褒</span><span begin="00:32.227" end="00:32.611">め</span><span begin="00:32.611" end="00:32.963">ら</span><span begin="00:32.963" end="00:33.195">れ</span><span begin="00:33.195" end="00:33.516">る</span><span begin="00:33.516" end="00:33.851">た</span><span begin="00:33.851" end="00:34.019">め</span><span begin="00:34.019" end="00:34.347">に</span><span begin="00:34.347" end="00:34.539">目</span><span begin="00:34.539" end="00:34.731">指</span><span begin="00:34.731" end="00:35.262">す</span><span ttm:role="x-translation" xml:lang="zh-CN">如此 我也依然愿意为了被认同而前行</span></p><p begin="00:35.262" end="00:38.607" ttm:agent="v1" itunes:key="L8"><span begin="00:35.262" end="00:35.526">晴</span><span begin="00:35.526" end="00:36.006">れ</span><span begin="00:36.006" end="00:36.502">も</span><span begin="00:36.502" end="00:36.686">い</span><span begin="00:36.686" end="00:36.870">い</span><span begin="00:36.870" end="00:37.054">ん</span><span begin="00:37.054" end="00:37.334">で</span><span begin="00:37.334" end="00:37.779">し</span><span begin="00:37.779" end="00:38.224">ょ</span><span begin="00:38.225" end="00:38.607">う</span><span ttm:role="x-translation" xml:lang="zh-CN">天晴了 似乎也不错 不是吗</span></p><p begin="00:39.103" end="00:41.226" ttm:agent="v1" itunes:key="L9"><span begin="00:39.103" end="00:39.551">没</span><span begin="00:39.551" end="00:40.031">頭</span><span begin="00:40.031" end="00:40.239">し</span><span begin="00:40.239" end="00:41.226">て</span><span ttm:role="x-translation" xml:lang="zh-CN">要认真一点诶</span></p><p begin="00:41.226" end="00:46.950" ttm:agent="v1" itunes:key="L10"><span begin="00:41.226" end="00:41.329">ち</span><span begin="00:41.330" end="00:41.433">っ</span><span begin="00:41.433" end="00:41.513">ち</span><span begin="00:41.513" end="00:41.593">ゃ</span><span begin="00:41.593" end="00:41.745">い</span><span begin="00:41.745" end="00:42.065">悪</span><span begin="00:42.065" end="00:42.217">魔</span><span begin="00:42.217" end="00:42.441">に</span><span begin="00:42.441" end="00:42.673">な</span><span begin="00:42.673" end="00:42.889">れ</span><span begin="00:42.889" end="00:43.113">た</span><span begin="00:43.113" end="00:43.433">ら</span><span begin="00:43.433" end="00:43.873">楽</span><span begin="00:43.873" end="00:44.577">で</span><span begin="00:44.577" end="00:45.214">す</span><span begin="00:45.214" end="00:45.646">頑</span><span begin="00:45.646" end="00:45.814">張</span><span begin="00:45.814" end="00:46.950">ろ</span><span ttm:role="x-translation" xml:lang="zh-CN">要是能化身为小恶魔就好了 继续加油吧</span></p><p begin="00:46.950" end="00:48.910" ttm:agent="v1" itunes:key="L11"><span begin="00:46.950" end="00:47.214">た</span><span begin="00:47.214" end="00:47.678">だ</span><span begin="00:47.678" end="00:48.118">凌</span><span begin="00:48.118" end="00:48.270">い</span><span begin="00:48.270" end="00:48.910">で</span><span ttm:role="x-translation" xml:lang="zh-CN">还是说只是想短暂逃避而已吗</span></p><p begin="00:48.910" end="00:52.902" ttm:agent="v1" itunes:key="L12"><span begin="00:48.910" end="00:49.230">魘</span><span begin="00:49.230" end="00:49.470">さ</span><span begin="00:49.470" end="00:49.646">れ</span><span begin="00:49.646" end="00:49.854">る</span><span begin="00:49.854" end="00:50.006">の</span><span begin="00:50.006" end="00:50.167">も</span><span begin="00:50.167" end="00:50.446">一</span><span begin="00:50.446" end="00:50.654">時</span><span begin="00:50.654" end="00:51.095">的</span><span begin="00:51.095" end="00:51.438">な</span><span begin="00:51.438" end="00:51.574">所</span><span begin="00:51.574" end="00:51.862">業</span><span begin="00:51.958" end="00:52.350">一</span><span begin="00:52.350" end="00:52.494">過</span><span begin="00:52.494" end="00:52.902">性</span><span ttm:role="x-translation" xml:lang="zh-CN">可梦魇也只是短暂的</span></p><p begin="00:52.902" end="00:55.647" ttm:agent="v1" itunes:key="L13"><span begin="00:52.902" end="00:53.142">言</span><span begin="00:53.142" end="00:53.382">い</span><span begin="00:53.382" end="00:54.759">訳</span><span begin="00:54.759" end="00:55.239">で</span><span begin="00:55.239" end="00:55.647">す</span><span ttm:role="x-translation" xml:lang="zh-CN">终究只是个借口吗</span></p><p begin="00:56.025" end="01:00.041" ttm:agent="v1" itunes:key="L14"><span begin="00:56.025" end="00:56.173">ロ</span><span begin="00:56.173" end="00:56.321">ン</span><span begin="00:56.321" end="00:56.505">リ</span><span begin="00:56.505" end="00:56.689">ー</span><span begin="00:56.689" end="00:56.905">ナ</span><span begin="00:56.905" end="00:57.201">イ</span><span begin="00:57.201" end="00:57.386">ト</span><span begin="00:57.386" end="00:57.913">冷</span><span begin="00:57.913" end="00:58.345">蔵</span><span begin="00:58.345" end="00:58.697">庫</span><span begin="00:58.697" end="00:58.929">の</span><span begin="00:58.929" end="00:59.386">灯</span><span begin="00:59.386" end="00:59.690">り</span><span begin="00:59.690" end="01:00.041">が</span><span ttm:role="x-translation" xml:lang="zh-CN">于孤独的深夜静默 冰箱里闪灼的灯光</span></p><p begin="01:00.041" end="01:04.093" ttm:agent="v1" itunes:key="L15"><span begin="01:00.041" end="01:00.569">映</span><span begin="01:00.569" end="01:00.929">し</span><span begin="01:00.929" end="01:01.153">出</span><span begin="01:01.153" end="01:01.393">す</span><span begin="01:01.393" end="01:01.793">僕</span><span begin="01:01.793" end="01:02.041">の</span><span begin="01:02.041" end="01:02.281">虚</span><span begin="01:02.281" end="01:02.481">無</span><span begin="01:02.481" end="01:02.753">を</span><span begin="01:02.753" end="01:03.193">証</span><span begin="01:03.193" end="01:03.617">明</span><span begin="01:03.617" end="01:03.785">し</span><span begin="01:03.785" end="01:04.093">て</span><span ttm:role="x-translation" xml:lang="zh-CN">映照着 证明着我的虚无</span></p><p begin="01:04.093" end="01:07.757" ttm:agent="v1" itunes:key="L16"><span begin="01:04.093" end="01:04.333">そ</span><span begin="01:04.333" end="01:04.533">れ</span><span begin="01:04.533" end="01:04.949">は</span><span begin="01:04.949" end="01:05.349">誰</span><span begin="01:05.349" end="01:05.557">も</span><span begin="01:05.557" end="01:06.061">奪</span><span begin="01:06.061" end="01:06.333">え</span><span begin="01:06.333" end="01:06.517">や</span><span begin="01:06.517" end="01:06.669">し</span><span begin="01:06.669" end="01:06.853">な</span><span begin="01:06.853" end="01:06.981">い</span><span begin="01:06.981" end="01:07.109">ん</span><span begin="01:07.109" end="01:07.381">だ</span><span begin="01:07.381" end="01:07.757">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">那是 谁也无法夺走的事物啊</span></p><p begin="01:07.757" end="01:12.651" ttm:agent="v1" itunes:key="L17"><span begin="01:07.757" end="01:08.054">孤</span><span begin="01:08.054" end="01:08.765">独</span><span begin="01:08.765" end="01:08.929">じ</span><span begin="01:08.929" end="01:09.093">ゃ</span><span begin="01:09.093" end="01:09.277">な</span><span begin="01:09.277" end="01:09.425">き</span><span begin="01:09.425" end="01:09.573">ゃ</span><span begin="01:09.574" end="01:10.005">眠</span><span begin="01:10.005" end="01:10.301">れ</span><span begin="01:10.301" end="01:10.805">な</span><span begin="01:10.805" end="01:11.365">い</span><span begin="01:11.660" end="01:12.012">眠</span><span begin="01:12.012" end="01:12.172">れ</span><span begin="01:12.172" end="01:12.300">な</span><span begin="01:12.300" end="01:12.651">い</span><span ttm:role="x-translation" xml:lang="zh-CN">不孤独的话 我将无法入梦 得以安睡</span></p><p begin="01:27.632" end="01:31.065" ttm:agent="v1" itunes:key="L18"><span begin="01:27.632" end="01:28.176">空</span><span begin="01:28.176" end="01:28.400">っ</span><span begin="01:28.400" end="01:28.712">ぽ</span><span begin="01:28.712" end="01:28.840">な</span><span begin="01:28.840" end="01:29.096">オ</span><span begin="01:29.096" end="01:29.336">ケ</span><span begin="01:29.336" end="01:29.624">で</span><span begin="01:29.624" end="01:30.176">歌</span><span begin="01:30.176" end="01:30.328">う</span><span begin="01:30.328" end="01:30.632">習</span><span begin="01:30.632" end="01:31.065">慣</span><span ttm:role="x-translation" xml:lang="zh-CN">已经习惯了在空洞的伴奏声中歌唱</span></p><p begin="01:31.065" end="01:34.865" ttm:agent="v1" itunes:key="L19"><span begin="01:31.065" end="01:31.552">新</span><span begin="01:31.552" end="01:32.017">参</span><span begin="01:32.017" end="01:32.281">お</span><span begin="01:32.281" end="01:32.776">皿</span><span begin="01:32.776" end="01:33.008">を</span><span begin="01:33.008" end="01:33.232">舐</span><span begin="01:33.232" end="01:33.432">め</span><span begin="01:33.432" end="01:33.688">る</span><span begin="01:33.688" end="01:34.072">探</span><span begin="01:34.072" end="01:34.401">究</span><span begin="01:34.401" end="01:34.545">死</span><span begin="01:34.545" end="01:34.865">因</span><span ttm:role="x-translation" xml:lang="zh-CN">如同新人一般舔舐餐盘 追寻着死亡的原因</span></p><p begin="01:34.865" end="01:38.722" ttm:agent="v1" itunes:key="L20"><span begin="01:34.865" end="01:35.176">や</span><span begin="01:35.176" end="01:35.408">り</span><span begin="01:35.408" end="01:35.608">た</span><span begin="01:35.608" end="01:35.928">い</span><span begin="01:35.928" end="01:36.128">こ</span><span begin="01:36.128" end="01:36.384">と</span><span begin="01:36.384" end="01:36.648">で</span><span begin="01:36.648" end="01:36.872">き</span><span begin="01:36.872" end="01:37.097">な</span><span begin="01:37.097" end="01:37.280">く</span><span begin="01:37.280" end="01:37.497">て</span><span begin="01:37.497" end="01:37.920">正</span><span begin="01:37.920" end="01:38.328">解</span><span begin="01:38.328" end="01:38.442">じ</span><span begin="01:38.443" end="01:38.557">ゃ</span><span begin="01:38.557" end="01:38.722">ん</span><span ttm:role="x-translation" xml:lang="zh-CN">不能随心所欲 也是正确的吗</span></p><p begin="01:38.723" end="01:42.571" ttm:agent="v1" itunes:key="L21"><span begin="01:38.723" end="01:38.951">言</span><span begin="01:38.951" end="01:39.179">い</span><span begin="01:39.179" end="01:39.403">た</span><span begin="01:39.403" end="01:39.691">い</span><span begin="01:39.691" end="01:40.059">こ</span><span begin="01:40.059" end="01:40.299">と</span><span begin="01:40.299" end="01:40.499">言</span><span begin="01:40.499" end="01:40.723">え</span><span begin="01:40.723" end="01:40.947">な</span><span begin="01:40.947" end="01:41.122">く</span><span begin="01:41.122" end="01:41.362">て</span><span begin="01:41.362" end="01:41.699">正</span><span begin="01:41.699" end="01:42.219">解</span><span begin="01:42.219" end="01:42.336">じ</span><span begin="01:42.336" end="01:42.453">ゃ</span><span begin="01:42.454" end="01:42.571">ん</span><span ttm:role="x-translation" xml:lang="zh-CN">不能表明心意 也是正确的吧</span></p><p begin="01:42.571" end="01:46.461" ttm:agent="v1" itunes:key="L22"><span begin="01:42.571" end="01:42.891">ア</span><span begin="01:42.891" end="01:43.139">ド</span><span begin="01:43.139" end="01:43.339">バ</span><span begin="01:43.339" end="01:43.467">イ</span><span begin="01:43.467" end="01:43.691">ス</span><span begin="01:43.691" end="01:43.946">評</span><span begin="01:43.946" end="01:44.331">論</span><span begin="01:44.331" end="01:44.707">人</span><span begin="01:44.707" end="01:45.275">類</span><span begin="01:45.275" end="01:45.603">脳</span><span begin="01:45.603" end="01:45.818">サ</span><span begin="01:45.818" end="01:46.033">ン</span><span begin="01:46.034" end="01:46.210">キ</span><span begin="01:46.210" end="01:46.461">ュ</span><span ttm:role="x-translation" xml:lang="zh-CN">非议与批判 真是感谢你的费心啊</span></p><p begin="01:46.462" end="01:50.686" ttm:agent="v1" itunes:key="L23"><span begin="01:46.462" end="01:46.694">す</span><span begin="01:46.694" end="01:47.030">り</span><span begin="01:47.030" end="01:47.342">減</span><span begin="01:47.342" end="01:47.574">ら</span><span begin="01:47.574" end="01:47.766">な</span><span begin="01:47.766" end="01:47.966">い</span><span begin="01:47.966" end="01:48.214">日</span><span begin="01:48.214" end="01:48.478">を</span><span begin="01:48.478" end="01:48.998">選</span><span begin="01:48.998" end="01:49.190">ぼ</span><span begin="01:49.190" end="01:49.382">う</span><span begin="01:49.382" end="01:49.782">よ</span><span begin="01:49.782" end="01:50.074">だ</span><span begin="01:50.074" end="01:50.366">っ</span><span begin="01:50.366" end="01:50.686">て</span><span ttm:role="x-translation" xml:lang="zh-CN">挑选一个不会使自己疲倦 消磨热情的日子吧</span></p><p begin="01:50.686" end="01:52.986" ttm:agent="v1" itunes:key="L24"><span begin="01:50.686" end="01:50.878">余</span><span begin="01:50.878" end="01:51.398">裕</span><span begin="01:51.398" end="01:51.766">が</span><span begin="01:51.766" end="01:51.958">な</span><span begin="01:51.958" end="01:52.166">い</span><span begin="01:52.166" end="01:52.622">僕</span><span begin="01:52.622" end="01:52.822">に</span><span begin="01:52.822" end="01:52.986">は</span><span ttm:role="x-translation" xml:lang="zh-CN">因为我早已没有太多的时间</span></p><p begin="01:52.986" end="01:56.978" ttm:agent="v1" itunes:key="L25"><span begin="01:52.986" end="01:53.402">劣</span><span begin="01:53.402" end="01:53.842">等</span><span begin="01:53.842" end="01:54.103">感</span><span begin="01:54.103" end="01:54.233">・</span><span begin="01:54.234" end="01:54.658">疎</span><span begin="01:54.658" end="01:55.178">外</span><span begin="01:55.178" end="01:55.487">感</span><span begin="01:55.487" end="01:55.641">・</span><span begin="01:55.642" end="01:56.114">嫌</span><span begin="01:56.114" end="01:56.298">悪</span><span begin="01:56.298" end="01:56.698">感</span><span begin="01:56.698" end="01:56.978">が</span><span ttm:role="x-translation" xml:lang="zh-CN">浓郁的自卑 淡漠的疏离 深沉的厌恶</span></p><p begin="01:56.978" end="02:03.050" ttm:agent="v1" itunes:key="L26"><span begin="01:56.978" end="01:57.322">成</span><span begin="01:57.322" end="01:57.730">長</span><span begin="01:57.730" end="01:57.970">な</span><span begin="01:57.970" end="01:58.210">ん</span><span begin="01:58.210" end="01:58.482">て</span><span begin="01:58.482" end="01:58.978">今</span><span begin="01:58.978" end="02:00.538">は</span><span begin="02:00.538" end="02:00.874">無</span><span begin="02:00.874" end="02:01.178">理</span><span begin="02:01.178" end="02:01.370">だ</span><span begin="02:01.370" end="02:03.050">な</span><span ttm:role="x-translation" xml:lang="zh-CN">还是无法逃脱吗</span></p><p begin="02:05.728" end="02:09.608" ttm:agent="v1" itunes:key="L27"><span begin="02:05.728" end="02:05.844">ロ</span><span begin="02:05.844" end="02:05.960">ン</span><span begin="02:05.960" end="02:06.116">リ</span><span begin="02:06.116" end="02:06.272">ー</span><span begin="02:06.272" end="02:06.632">ナ</span><span begin="02:06.632" end="02:06.920">イ</span><span begin="02:06.920" end="02:07.112">ト</span><span begin="02:07.112" end="02:07.496">冷</span><span begin="02:07.496" end="02:07.832">蔵</span><span begin="02:07.832" end="02:08.184">庫</span><span begin="02:08.184" end="02:08.504">の</span><span begin="02:08.504" end="02:09.040">灯</span><span begin="02:09.040" end="02:09.280">り</span><span begin="02:09.280" end="02:09.608">が</span><span ttm:role="x-translation" xml:lang="zh-CN">在孤独的深夜静默 冰箱里刺眼的灯光</span></p><p begin="02:09.608" end="02:13.550" ttm:agent="v1" itunes:key="L28"><span begin="02:09.608" end="02:10.184">映</span><span begin="02:10.184" end="02:10.472">し</span><span begin="02:10.472" end="02:10.760">出</span><span begin="02:10.760" end="02:10.928">す</span><span begin="02:10.928" end="02:11.424">僕</span><span begin="02:11.424" end="02:11.648">の</span><span begin="02:11.648" end="02:11.896">虚</span><span begin="02:11.896" end="02:12.112">無</span><span begin="02:12.112" end="02:12.376">を</span><span begin="02:12.376" end="02:12.816">証</span><span begin="02:12.816" end="02:13.192">明</span><span begin="02:13.192" end="02:13.352">し</span><span begin="02:13.352" end="02:13.550">て</span><span ttm:role="x-translation" xml:lang="zh-CN">又一次映照着 证明着我的虚无</span></p><p begin="02:13.550" end="02:17.398" ttm:agent="v1" itunes:key="L29"><span begin="02:13.550" end="02:13.774">そ</span><span begin="02:13.774" end="02:14.062">れ</span><span begin="02:14.062" end="02:14.518">は</span><span begin="02:14.518" end="02:15.030">誰</span><span begin="02:15.030" end="02:15.270">も</span><span begin="02:15.270" end="02:15.758">奪</span><span begin="02:15.758" end="02:15.982">え</span><span begin="02:15.982" end="02:16.166">や</span><span begin="02:16.166" end="02:16.310">し</span><span begin="02:16.310" end="02:16.518">な</span><span begin="02:16.518" end="02:16.622">い</span><span begin="02:16.622" end="02:16.726">ん</span><span begin="02:16.726" end="02:17.062">だ</span><span begin="02:17.062" end="02:17.398">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">那是我无法被人夺去的事物啊</span></p><p begin="02:17.398" end="02:22.432" ttm:agent="v1" itunes:key="L30"><span begin="02:17.398" end="02:17.654">孤</span><span begin="02:17.654" end="02:18.398">独</span><span begin="02:18.398" end="02:18.530">じ</span><span begin="02:18.530" end="02:18.662">ゃ</span><span begin="02:18.662" end="02:18.902">な</span><span begin="02:18.902" end="02:19.010">き</span><span begin="02:19.010" end="02:19.118">ゃ</span><span begin="02:19.118" end="02:19.622">眠</span><span begin="02:19.622" end="02:19.886">れ</span><span begin="02:19.886" end="02:20.606">な</span><span begin="02:20.606" end="02:21.038">い</span><span begin="02:21.350" end="02:21.686">眠</span><span begin="02:21.686" end="02:21.854">れ</span><span begin="02:21.854" end="02:22.014">な</span><span begin="02:22.014" end="02:22.432">い</span><span ttm:role="x-translation" xml:lang="zh-CN">我已明白 只有如此 才能安眠</span></p><p begin="02:37.299" end="02:39.320" ttm:agent="v1" itunes:key="L31"><span begin="02:37.299" end="02:37.459">ほ</span><span begin="02:37.459" end="02:37.619">っ</span><span begin="02:37.619" end="02:37.907">と</span><span begin="02:37.907" end="02:38.075">い</span><span begin="02:38.075" end="02:39.320">て</span><span ttm:role="x-translation" xml:lang="zh-CN">已经无所谓了 随它去吧</span></p><p begin="02:39.320" end="02:45.019" ttm:agent="v1" itunes:key="L32"><span begin="02:39.320" end="02:39.728">解</span><span begin="02:39.728" end="02:39.904">い</span><span begin="02:39.904" end="02:40.056">た</span><span begin="02:40.056" end="02:40.216">凝</span><span begin="02:40.216" end="02:40.368">り</span><span begin="02:40.368" end="02:40.512">素</span><span begin="02:40.512" end="02:40.960">早</span><span begin="02:40.960" end="02:41.216">く</span><span begin="02:41.216" end="02:41.528">手</span><span begin="02:41.528" end="02:42.008">放</span><span begin="02:42.008" end="02:43.360">せ</span><span begin="02:43.360" end="02:43.824">頑</span><span begin="02:43.824" end="02:43.984">張</span><span begin="02:43.984" end="02:45.019">ろ</span><span ttm:role="x-translation" xml:lang="zh-CN">快些释放积累的困倦与疲惫吧 要更努力噢</span></p><p begin="02:45.019" end="02:47.022" ttm:agent="v1" itunes:key="L33"><span begin="02:45.019" end="02:45.195">木</span><span begin="02:45.195" end="02:45.587">枯</span><span begin="02:45.587" end="02:45.787">ら</span><span begin="02:45.787" end="02:46.107">し</span><span begin="02:46.107" end="02:46.306">吹</span><span begin="02:46.306" end="02:47.022">け</span><span ttm:role="x-translation" xml:lang="zh-CN">凛风掠过</span></p><p begin="02:47.022" end="02:50.997" ttm:agent="v1" itunes:key="L34"><span begin="02:47.022" end="02:47.222">安</span><span begin="02:47.222" end="02:47.462">心</span><span begin="02:47.462" end="02:47.582">な</span><span begin="02:47.582" end="02:47.702">ん</span><span begin="02:47.702" end="02:47.950">て</span><span begin="02:47.950" end="02:48.454">一</span><span begin="02:48.454" end="02:48.686">時</span><span begin="02:48.686" end="02:49.182">的</span><span begin="02:49.182" end="02:49.478">な</span><span begin="02:49.478" end="02:49.614">諸</span><span begin="02:49.614" end="02:49.896">行</span><span begin="02:49.990" end="02:50.398">一</span><span begin="02:50.398" end="02:50.558">過</span><span begin="02:50.558" end="02:50.997">性</span><span ttm:role="x-translation" xml:lang="zh-CN">内心的平静也只是昙花一现 世事无常</span></p><p begin="02:50.997" end="02:53.745" ttm:agent="v1" itunes:key="L35"><span begin="02:50.997" end="02:51.225">い</span><span begin="02:51.225" end="02:51.453">い</span><span begin="02:51.454" end="02:51.630">加</span><span begin="02:51.630" end="02:52.800">減</span><span begin="02:52.800" end="02:53.247">で</span><span begin="02:53.247" end="02:53.745">す</span><span ttm:role="x-translation" xml:lang="zh-CN">也只是随心而动</span></p><p begin="02:54.170" end="02:59.370" ttm:agent="v1" itunes:key="L36"><span begin="02:54.170" end="02:54.754">皆</span><span begin="02:54.754" end="02:55.194">が</span><span begin="02:55.194" end="02:55.342">い</span><span begin="02:55.342" end="02:55.490">い</span><span begin="02:55.490" end="02:55.721">と</span><span begin="02:55.721" end="02:56.117">思</span><span begin="02:56.118" end="02:56.290">う</span><span begin="02:56.290" end="02:56.898">曲</span><span begin="02:56.898" end="02:57.194">や</span><span begin="02:57.194" end="02:57.698">歌</span><span begin="02:57.698" end="02:58.042">が</span><span begin="02:58.042" end="02:58.690">響</span><span begin="02:58.690" end="02:58.994">か</span><span begin="02:58.994" end="02:59.146">な</span><span begin="02:59.146" end="02:59.370">い</span><span ttm:role="x-translation" xml:lang="zh-CN">人们所认同的歌声和乐曲都无法使我得到慰籍</span></p><p begin="02:59.370" end="03:02.050" ttm:agent="v1" itunes:key="L37"><span begin="02:59.370" end="02:59.842">弱</span><span begin="02:59.842" end="03:00.058">る</span><span begin="03:00.058" end="03:00.498">夜</span><span begin="03:00.498" end="03:00.786">を</span><span begin="03:00.786" end="03:01.202">肯</span><span begin="03:01.202" end="03:01.578">定</span><span begin="03:01.578" end="03:01.746">し</span><span begin="03:01.746" end="03:02.050">て</span><span ttm:role="x-translation" xml:lang="zh-CN">反而肯定了那些让我脆弱的夜晚</span></p><p begin="03:02.050" end="03:06.391" ttm:agent="v1" itunes:key="L38"><span begin="03:02.050" end="03:02.250">そ</span><span begin="03:02.250" end="03:02.554">の</span><span begin="03:02.554" end="03:02.954">手</span><span begin="03:02.954" end="03:03.490">時</span><span begin="03:03.490" end="03:03.738">に</span><span begin="03:03.738" end="03:03.946">は</span><span begin="03:03.946" end="03:04.178">借</span><span begin="03:04.178" end="03:04.398">り</span><span begin="03:04.398" end="03:04.582">て</span><span begin="03:04.582" end="03:04.718">み</span><span begin="03:04.718" end="03:04.934">た</span><span begin="03:04.934" end="03:05.166">い</span><span begin="03:05.166" end="03:05.463">け</span><span begin="03:05.463" end="03:06.391">ど</span><span ttm:role="x-translation" xml:lang="zh-CN">有时也想借着那只手逃避</span></p><p begin="03:06.553" end="03:09.422" ttm:agent="v1" itunes:key="L39"><span begin="03:06.553" end="03:07.337">け</span><span begin="03:07.337" end="03:07.585">れ</span><span begin="03:07.585" end="03:08.249">ど</span><span begin="03:08.249" end="03:08.550">い</span><span begin="03:08.550" end="03:08.862">ら</span><span begin="03:08.862" end="03:09.110">な</span><span begin="03:09.110" end="03:09.422">い</span><span ttm:role="x-translation" xml:lang="zh-CN">但其实并不需要</span></p><p begin="03:09.650" end="03:13.614" ttm:agent="v1" itunes:key="L40"><span begin="03:09.650" end="03:09.906">論</span><span begin="03:09.906" end="03:10.274">理</span><span begin="03:10.274" end="03:10.602">無</span><span begin="03:10.602" end="03:10.786">い</span><span begin="03:10.786" end="03:10.994">と</span><span begin="03:10.994" end="03:11.426">夢</span><span begin="03:11.426" end="03:11.642">は</span><span begin="03:11.642" end="03:12.114">苦</span><span begin="03:12.114" end="03:12.386">さ</span><span begin="03:12.386" end="03:12.658">を</span><span begin="03:12.658" end="03:13.026">増</span><span begin="03:13.026" end="03:13.186">し</span><span begin="03:13.186" end="03:13.614">て</span><span ttm:role="x-translation" xml:lang="zh-CN">缺失逻辑的幻梦 越发苦涩难咽</span></p><p begin="03:13.614" end="03:17.260" ttm:agent="v1" itunes:key="L41"><span begin="03:13.614" end="03:13.949">夢</span><span begin="03:13.949" end="03:14.165">で</span><span begin="03:14.165" end="03:14.373">会</span><span begin="03:14.373" end="03:14.519">お</span><span begin="03:14.520" end="03:14.666">う</span><span begin="03:14.666" end="03:14.812">？</span><span begin="03:14.813" end="03:15.017">な</span><span begin="03:15.017" end="03:15.199">ん</span><span begin="03:15.199" end="03:15.527">て</span><span begin="03:15.527" end="03:15.751">こ</span><span begin="03:15.751" end="03:15.975">と</span><span begin="03:15.975" end="03:16.264">は</span><span begin="03:16.264" end="03:16.514">ま</span><span begin="03:16.514" end="03:16.753">や</span><span begin="03:16.753" end="03:17.194">か</span><span begin="03:17.194" end="03:17.260">し</span><span ttm:role="x-translation" xml:lang="zh-CN">在梦境里相会吗？只是虚幻的谎言罢了</span></p><p begin="03:17.260" end="03:21.319" ttm:agent="v1" itunes:key="L42"><span begin="03:17.260" end="03:17.492">で</span><span begin="03:17.492" end="03:17.684">も</span><span begin="03:17.684" end="03:17.852">そ</span><span begin="03:17.852" end="03:18.004">れ</span><span begin="03:18.004" end="03:18.436">は</span><span begin="03:18.436" end="03:18.884">僕</span><span begin="03:18.884" end="03:19.101">の</span><span begin="03:19.101" end="03:19.349">生</span><span begin="03:19.349" end="03:19.581">存</span><span begin="03:19.581" end="03:19.861">戦</span><span begin="03:19.861" end="03:20.197">略</span><span begin="03:20.197" end="03:20.413">な</span><span begin="03:20.413" end="03:20.629">ん</span><span begin="03:20.629" end="03:20.901">だ</span><span begin="03:20.901" end="03:21.319">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">可这就是我得以生存的策略啊</span></p><p begin="03:21.319" end="03:26.182" ttm:agent="v1" itunes:key="L43"><span begin="03:21.319" end="03:21.544">孤</span><span begin="03:21.544" end="03:22.271">独</span><span begin="03:22.271" end="03:22.403">じ</span><span begin="03:22.403" end="03:22.535">ゃ</span><span begin="03:22.535" end="03:22.775">な</span><span begin="03:22.775" end="03:22.907">き</span><span begin="03:22.907" end="03:23.039">ゃ</span><span begin="03:23.039" end="03:23.559">眠</span><span begin="03:23.559" end="03:23.815">れ</span><span begin="03:23.815" end="03:24.519">な</span><span begin="03:24.519" end="03:24.904">い</span><span begin="03:25.159" end="03:25.479">眠</span><span begin="03:25.479" end="03:25.639">れ</span><span begin="03:25.639" end="03:25.808">な</span><span begin="03:25.808" end="03:26.182">い</span><span ttm:role="x-translation" xml:lang="zh-CN">失去孤独的我 难以安眠</span></p></div></body></tt>